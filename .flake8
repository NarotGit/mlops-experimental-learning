[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    notebooks,
    mlruns,
    models,
    reports,
    screenshots
ignore =
    E203,
    W503,
    E402,
    E221,
    W291,
    W292,
    W293,
    E302,
    F401,
    F811
per-file-ignores =
    tests/*:S101